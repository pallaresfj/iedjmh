APP_NAME="IED AGROPECUARIA JOSE MARIA HERRERA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://iedjmh.edu.co
ASSET_URL="${APP_URL}"
APP_TIMEZONE=America/Bogota

# ---------- Authentication: Google OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ---------- Institution ----------
INSTITUTION_ADDRESS="Pivijay, Magdalena, Colombia"
INSTITUTION_PHONE=
INSTITUTION_EMAIL=

# ---------- Locale ----------
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

# ---------- Maintenance ----------
APP_MAINTENANCE_DRIVER=file

# ---------- Security ----------
BCRYPT_ROUNDS=12

# ---------- Logging ----------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------- Database (MySQL) ----------
DB_CONNECTION=mysql
DB_HOST=iedjmh-mysql
DB_PORT=3306
DB_DATABASE=iedjmh
DB_USERNAME=iedjmh
DB_PASSWORD=

# ---------- Session ----------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ---------- Broadcasting / Filesystem / Queue / Cache ----------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ---------- Redis (optional, recommended for production) ----------
# If Redis is enabled in your environment:
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# REDIS_CLIENT=phpredis
# REDIS_HOST=iedjmh-redis
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ---------- Mail ----------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@iedjmh.edu.co"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- AWS / S3 (optional, for file storage) ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------- Vite ----------
VITE_APP_NAME="${APP_NAME}"
